# Copy to `.env` for local dev. Never commit real secrets.

# Firebase client (public) — see Firebase console Web app config
# NEXT_PUBLIC_FIREBASE_API_KEY=
# ...

# Firebase Admin (server) — one of FIREBASE_SERVICE_ACCOUNT_KEY, _BASE64, or ADC
# FIREBASE_SERVICE_ACCOUNT_KEY=

# Google Maps (optional, for maps on city / add-ad pages)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Places API (New) — server: `scripts/import-places-draft.mjs` + `/api/places/photo`
# Enable "Places API (New)" in GCP; prefer a key restricted to that API.
# GOOGLE_PLACES_API_KEY=

# OpenAI — logged-in AI search on city listings + AI-assisted add-ad draft (server-only)
OPENAI_API_KEY=
# Optional override; default is gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini
