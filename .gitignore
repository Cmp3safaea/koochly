# Never use blanket *.json — it prevents committing package.json / lockfiles and breaks Docker + Cloud Build.
# Ignore common credential / dump JSON instead:
**/firebase-adminsdk*.json
**/*-service-account*.json
# Common local filename for downloaded GCP service account keys (do not commit).
service.json

# Local Places import drafts (may contain POI dumps)
nextjs-firebase/tmp/places-import-draft.json

